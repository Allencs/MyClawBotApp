# ===== 私人 AI 管家 / WeChat ClawBot MVP =====
# 复制为 .env 后填入真实值；切勿提交到 git。

# OpenRouter API Key（默认 LLM 通道）
# 申请：https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-replace-me

# 默认模型（与 config/openclaw.template.json 中 providers.openrouter.models 的 key 对应）
# 可选：gemini-flash-lite | gemini-pro | claude-sonnet | deepseek-chat
OPENCLAW_DEFAULT_MODEL=gemini-flash-lite

# OpenClaw 配置存放目录（一般无需修改）
OPENCLAW_HOME=$HOME/.openclaw

# Gateway 监听地址（默认 127.0.0.1:8421，仅本机访问）
OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=8421
